{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:write-all"
    },
    "shell:default",
    "process:default",
    "process:allow-exit",
    "core:webview:allow-set-webview-zoom",
    "notification:default"
  ]
}
