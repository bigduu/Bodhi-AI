{
  "name": "bodhi-shell",
  "private": true,
  "version": "2026.3.8",
  "type": "module",
  "scripts": {
    "dev": "npm --prefix ../lotus run dev",
    "build": "npm --prefix ../lotus run build",
    "preview": "npm --prefix ../lotus run preview",
    "type-check": "npm --prefix ../lotus run type-check",
    "test": "npm --prefix ../lotus run test",
    "test:run": "npm --prefix ../lotus run test:run",
    "format": "npm --prefix ../lotus run format",
    "format:check": "npm --prefix ../lotus run format:check",
    "web:dev": "npm --prefix ../lotus run dev",
    "web:build": "npm --prefix ../lotus run build",
    "web:type-check": "npm --prefix ../lotus run type-check",
    "web:rebrand:public": "npm --prefix ../lotus run rebrand:public",
    "web:rebrand:internal": "npm --prefix ../lotus run rebrand:internal",
    "web:rebrand:check": "npm --prefix ../lotus run rebrand:check",
    "shell:rebrand:public": "node scripts/rebrand-shell.cjs --target=public",
    "shell:rebrand:internal": "node scripts/rebrand-shell.cjs --target=internal",
    "rebrand:public": "npm run web:rebrand:public",
    "rebrand:internal": "npm run web:rebrand:internal",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:dev:public": "npm run rebrand:public && node scripts/tauri-mode.cjs --mode=public --target=dev",
    "tauri:dev:internal": "npm run rebrand:internal && node scripts/tauri-mode.cjs --mode=internal --target=dev",
    "tauri:build:public": "npm run rebrand:public && node scripts/tauri-mode.cjs --mode=public --target=build",
    "tauri:build:internal": "npm run rebrand:internal && node scripts/tauri-mode.cjs --mode=internal --target=build",
    "test:e2e": "npm --prefix ../lotus/e2e run test --",
    "test:e2e:browser": "npm --prefix ../lotus/e2e run test:browser --",
    "test:e2e:ui": "npm --prefix ../lotus/e2e run test:ui --",
    "test:e2e:debug": "npm --prefix ../lotus/e2e run test:debug --",
    "test:e2e:report": "npm --prefix ../lotus/e2e run test:report --"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
